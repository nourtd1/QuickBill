{
  "expo": {
    "name": "QuickBill",
    "slug": "QuickBill",
    "scheme": "quickbill",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nourdevtd.quickbill",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "QuickBill uses the camera to scan receipts and QR codes.",
        "NSPhotoLibraryUsageDescription": "QuickBill needs access to your photo library to upload your business logo and receipts.",
        "NSMicrophoneUsageDescription": "QuickBill uses the microphone for voice notes and the AI assistant.",
        "NSFaceIDUsageDescription": "QuickBill uses Face ID to securely unlock the app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nourdevtd.quickbill",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "QuickBill uses the camera to scan receipts and QR codes.",
          "microphonePermission": "QuickBill uses the microphone for voice notes and the AI assistant."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QuickBill needs access to your photos to upload your business logo and receipts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1337ec",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "QuickBill uses Face ID to securely unlock the app."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "QuickBill uses the microphone for voice notes and the AI assistant."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "ee949ba2-e6c7-4801-80aa-42e6cbb343dc"
      },
      "router": {}
    },
    "owner": "nourtd1"
  }
}
