# ==========================================
# QUICKBILL — Variables d'Environnement
# Copie ce fichier en .env et remplis les valeurs
# ==========================================

# ==========================================
# SUPABASE (obligatoire)
# https://app.supabase.com → Settings → API
# ==========================================
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# GEMINI AI (obligatoire pour scan & OCR)
# https://aistudio.google.com/app/apikey
# ==========================================
EXPO_PUBLIC_GEMINI_API_KEY=AIzaSy...

# --- EMAILJS (Auth & Notifications) ---
# Inscrivez-vous sur https://www.emailjs.com/
EXPO_PUBLIC_EMAILJS_PUBLIC_KEY=ton_public_key_ici
EXPO_PUBLIC_EMAILJS_SERVICE_ID=ton_service_id_ici

# Templates EmailJS (Email Templates > Create New Template)
# Créez des templates et copiez leurs IDs ici
EXPO_PUBLIC_EMAILJS_TEMPLATE_WELCOME=id_template_bienvenue
EXPO_PUBLIC_EMAILJS_TEMPLATE_2FA=id_template_2fa
EXPO_PUBLIC_EMAILJS_TEMPLATE_RESET_PW=id_template_mot_de_passe
EXPO_PUBLIC_EMAILJS_TEMPLATE_EMAIL_CHANGE=id_template_changement_email

# --- NOTES IMPORTANTES ---
# 1. Dans Supabase : Authentication -> Providers -> Email -> DESACTIVER "Confirm Email"
# 2. Exécuter le script SQL admin_reset_password (voir doc) pour activer le Reset Password.

